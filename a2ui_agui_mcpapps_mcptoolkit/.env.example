# Local configuration only. Never commit real credentials or wallets.
AGENT_PORT=8080
# Defaults align with the financial database used by the observability demo.
TNS_ADMIN=/path/to/Wallet_financialdb
# Optional override; otherwise DB_URL is built from financialdb_high and TNS_ADMIN.
# DB_URL=jdbc:oracle:thin:@financialdb_high?TNS_ADMIN=/path/to/Wallet_financialdb
DB_USERNAME=FINANCIAL
DB_PASSWORD=replace-me
DB_POOL_NAME=InteractiveAiFinancialUcpPool
DB_POOL_INITIAL_SIZE=1
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=4
DB_CONNECTION_WAIT_SECONDS=10
DB_INACTIVE_CONNECTION_SECONDS=60
DB_ROW_PREFETCH=50
# Optional override. run.sh otherwise downloads and builds the pinned Oracle toolkit source.
# ORACLE_MCP_TOOLKIT_JAR=/absolute/path/to/oracle-db-mcp-toolkit-1.0.0.jar
# ORACLE_MCP_CONFIG_FILE=/absolute/path/to/oracle-db-mcp-toolkit/config/tools.yaml
REQUESTED_BY=demo.user@example.com
